{
  "name": "vinci",
  "version": "1.0.0",
  "description": "Vinci - Isometric scientific SVG illustration builder",
  "type": "module",
  "scripts": {
    "sync:assets": "node scripts/sync-reference-assets.mjs",
    "predev": "npm run sync:assets",
    "dev": "vite",
    "prebuild": "npm run sync:assets",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "svg",
    "isometric",
    "scientific-illustration",
    "react"
  ],
  "author": "",
  "license": "ISC",
